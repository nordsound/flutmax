{
  "Input Port Declaration": {
    "prefix": "in",
    "description": "Input port declaration",
    "body": [
      "in ${1:0} (${2:name}): ${3|signal,float,int,bang|};"
    ]
  },
  "Output Port Declaration": {
    "prefix": "out",
    "description": "Output port declaration",
    "body": [
      "out ${1:0} (${2:name}): ${3|signal,float,int,bang|};"
    ]
  },
  "Wire Declaration": {
    "prefix": "wire",
    "description": "Wire declaration",
    "body": [
      "wire ${1:name} = ${2:object}(${3:args});"
    ]
  },
  "Wire with Signal Object": {
    "prefix": "wire~",
    "description": "Wire declaration with signal (tilde) object",
    "body": [
      "wire ${1:name} = ${2:cycle}~(${3:440});"
    ]
  },
  "Output Assignment": {
    "prefix": "outa",
    "description": "Output assignment",
    "body": [
      "out[${1:0}] = ${2:wire};"
    ]
  },
  "Simple Synth Template": {
    "prefix": "synth",
    "description": "Simple synthesizer template",
    "body": [
      "in 0 (${1:freq}): float;",
      "",
      "out 0 (${2:audio}): signal;",
      "",
      "wire osc = cycle~(${1:freq});",
      "wire gain = mul~(osc, ${3:0.5});",
      "",
      "out[0] = gain;"
    ]
  },
  "Filter Template": {
    "prefix": "filter",
    "description": "Filter template with biquad~",
    "body": [
      "in 0 (${1:input}): signal;",
      "in 1 (${2:cutoff}): float;",
      "in 2 (${3:q}): float;",
      "",
      "out 0 (${4:filtered}): signal;",
      "",
      "wire ${4:filtered} = biquad~(${1:input}, ${2:cutoff}, ${3:q});",
      "",
      "out[0] = ${4:filtered};"
    ]
  },
  "Stereo Output Template": {
    "prefix": "stereo",
    "description": "Stereo output template",
    "body": [
      "out 0 (${1:left}): signal;",
      "out 1 (${2:right}): signal;",
      "",
      "wire ${3:source} = ${4:cycle}~(${5:440});",
      "",
      "out[0] = ${3:source};",
      "out[1] = ${3:source};"
    ]
  }
}
